{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",

  "redirects": [
    { "source": "https://www.dwellmbta.com/(.*)", "destination": "https://dwellmbta.com/$1", "permanent": true },
    { "source": "http://www.dwellmbta.com/(.*)",  "destination": "https://dwellmbta.com/$1", "permanent": true },
    { "source": "http://dwellmbta.com/(.*)",       "destination": "https://dwellmbta.com/$1", "permanent": true }
  ],

  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
