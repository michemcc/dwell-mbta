# ── DWELL Environment Variables ──────────────────────────────────────────────
# Copy this file to .env for local development.
# On Netlify, set these in Site Configuration → Environment Variables.
# NEVER commit .env to git.

# ── Local dev only (Vite) ─────────────────────────────────────────────────────
# Used when running `npm run dev` locally (direct MBTA calls, no proxy).
# In production (Netlify), the serverless function uses MBTA_API_KEY instead.
VITE_MBTA_API_KEY=your_mbta_api_key_here

# ── Netlify serverless functions (server-side, never exposed to browser) ──────
# These go in Netlify → Site configuration → Environment variables.
# Do NOT prefix with VITE_ — that would bake them into the JS bundle.

# MBTA API key for the server-side proxy (https://api-v3.mbta.com/)
MBTA_API_KEY=your_mbta_api_key_here

# Resend email for the feedback form (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Where feedback emails are sent and sent from
FEEDBACK_TO_EMAIL=your@email.com
FEEDBACK_FROM_EMAIL=onboarding@resend.dev
