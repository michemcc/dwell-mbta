# ── DWELL Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore already.

# ── Required ──────────────────────────────────────────────────────────────────
# MBTA API v3 key — free at https://api-v3.mbta.com/
VITE_MBTA_API_KEY=your_mbta_api_key_here

# ── Optional: Resend email for feedback form ──────────────────────────────────
# Get a free key at https://resend.com (100 emails/day free)
# Without this, the feedback form falls back to opening the user's mail client.
VITE_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email address that receives feedback submissions
VITE_FEEDBACK_TO_EMAIL=your@email.com

# "From" address — must be from a domain you've verified in Resend
# On the free tier you can use: onboarding@resend.dev (Resend's shared domain)
VITE_FEEDBACK_FROM_EMAIL=onboarding@resend.dev
